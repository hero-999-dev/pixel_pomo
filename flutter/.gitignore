# Only the portable parts are committed (lib/, test/, pubspec.yaml, assets/).
# The platform projects (ios/, android/) and build outputs are generated by CI via
# `flutter create`, so they're intentionally NOT tracked here.

.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
pubspec.lock
build/
ios/
android/
linux/
macos/
windows/
web/
.metadata
*.iml

# Python tool caches (tools/)
__pycache__/
*.pyc
