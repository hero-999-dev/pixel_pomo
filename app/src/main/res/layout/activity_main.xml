<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== Main timer screen ===== -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar: theme (left) + settings (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp">

            <ImageView
                android:id="@+id/themeBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_theme"
                android:src="@drawable/ic_palette" />

            <ImageView
                android:id="@+id/gardenBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_garden"
                android:src="@drawable/ic_garden" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/statsBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="20dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_stats"
                android:src="@drawable/ic_stats" />

            <ImageView
                android:id="@+id/settingsBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_settings"
                android:src="@drawable/ic_settings" />

            <!-- Coin balance (far right corner) — icon matches the settings-icon height (32dp),
                 with the count right beside it. Tap to open the shop. -->
            <LinearLayout
                android:id="@+id/coinBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_coins">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_coin" />

                <TextView
                    android:id="@+id/coinLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/press_start_2p"
                    android:textSize="14sp"
                    tools:ignore="HardcodedText"
                    android:text="0" />
            </LinearLayout>
        </LinearLayout>

        <!-- Centered timer content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/modeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/work"
                android:textSize="22sp" />

            <!-- Tappable focus-label chip: shows the current label, opens the label picker. -->
            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/labelBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/press_start_2p"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="10dp"
                android:stateListAnimator="@null"
                android:text="@string/label_title"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/press_start_2p"
                android:text="@string/initial_time"
                android:textSize="48sp" />

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"
                android:max="100"
                android:progress="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/startPauseBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="16dp"
                    android:stateListAnimator="@null"
                    android:text="@string/start"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/resetBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="16dp"
                    android:stateListAnimator="@null"
                    android:text="@string/reset"
                    android:textSize="14sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/switchModeBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@android:color/transparent"
                android:fontFamily="@font/press_start_2p"
                android:stateListAnimator="@null"
                android:text="@string/switch_mode"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/sessionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/press_start_2p"
                android:textSize="12sp"
                tools:ignore="HardcodedText"
                android:text="SESSION 1 / 4" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Settings overlay ===== -->
    <ScrollView
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="36dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/settings"
                android:textSize="20sp" />

            <!-- Study (work) minutes -->
            <include
                android:id="@+id/rowWork"
                layout="@layout/row_stepper" />

            <!-- Break minutes -->
            <include
                android:id="@+id/rowBreak"
                layout="@layout/row_stepper" />

            <!-- Sessions -->
            <include
                android:id="@+id/rowSessions"
                layout="@layout/row_stepper" />

            <!-- Language -->
            <TextView
                android:id="@+id/languageTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="14dp"
                android:fontFamily="@font/press_start_2p"
                android:text="@string/language"
                android:textSize="12sp" />

            <!-- Language buttons are added here in code. -->
            <LinearLayout
                android:id="@+id/languageList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/save"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/settingsCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/close"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ===== Theme overlay ===== -->
    <ScrollView
        android:id="@+id/themePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/themeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/theme"
                android:textSize="20sp" />

            <!-- Theme buttons are added here in code -->
            <LinearLayout
                android:id="@+id/themeList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/themeCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/close"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ===== Label overlay ===== -->
    <ScrollView
        android:id="@+id/labelPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/labelTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/label_title"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/labelHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/press_start_2p"
                android:lineSpacingExtra="4dp"
                android:text="@string/label_delete_hint"
                android:textSize="9sp" />

            <!-- Existing labels are listed here in code (tap = select, long-press = delete). -->
            <LinearLayout
                android:id="@+id/labelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- New-label input row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <EditText
                    android:id="@+id/labelInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="10dp"
                    android:fontFamily="@font/press_start_2p"
                    android:hint="@string/label_hint"
                    android:imeOptions="actionDone"
                    android:inputType="textCapCharacters"
                    android:maxLength="12"
                    android:padding="12dp"
                    android:textSize="11sp"
                    android:importantForAutofill="no"
                    tools:ignore="LabelFor" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/addLabelBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="14dp"
                    android:stateListAnimator="@null"
                    android:text="@string/add"
                    android:textSize="12sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/labelCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/close"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ===== Stats overlay ===== -->
    <ScrollView
        android:id="@+id/statsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/statsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/stats_title"
                android:textSize="20sp" />

            <!-- Month navigator: ◀  <Month Year>  ▶ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/monthPrevBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="12dp"
                    android:stateListAnimator="@null"
                    android:text="@string/prev_arrow"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/monthLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:fontFamily="@font/press_start_2p"
                    tools:ignore="HardcodedText"
                    android:text="JUNE 2026"
                    android:textSize="12sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/monthNextBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="12dp"
                    android:stateListAnimator="@null"
                    android:text="@string/next_arrow"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- Chart-style picker: choose how the month is graphed. -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/chartBarBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="12dp"
                    android:stateListAnimator="@null"
                    android:text="@string/chart_bar"
                    android:textSize="9sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/chartLineBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="12dp"
                    android:stateListAnimator="@null"
                    android:text="@string/chart_line"
                    android:textSize="9sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/chartPieBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="12dp"
                    android:stateListAnimator="@null"
                    android:text="@string/chart_pie"
                    android:textSize="9sp" />
            </LinearLayout>

            <com.pixelpomo.app.ChartView
                android:id="@+id/chart"
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginBottom="24dp" />

            <!-- TODAY / WEEK / MONTH / YEAR / ALL rows. Captions = child 0, values = last child. -->
            <LinearLayout
                android:id="@+id/statsBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout style="@style/StatRow">
                    <TextView style="@style/StatCaption" android:text="@string/stat_today" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    <TextView android:id="@+id/statToday" style="@style/StatValue" />
                </LinearLayout>

                <LinearLayout style="@style/StatRow">
                    <TextView style="@style/StatCaption" android:text="@string/stat_week" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    <TextView android:id="@+id/statWeek" style="@style/StatValue" />
                </LinearLayout>

                <LinearLayout style="@style/StatRow">
                    <TextView style="@style/StatCaption" android:text="@string/stat_month" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    <TextView android:id="@+id/statMonth" style="@style/StatValue" />
                </LinearLayout>

                <LinearLayout style="@style/StatRow">
                    <TextView style="@style/StatCaption" android:text="@string/stat_year" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    <TextView android:id="@+id/statYear" style="@style/StatValue" />
                </LinearLayout>

                <LinearLayout style="@style/StatRow">
                    <TextView style="@style/StatCaption" android:text="@string/stat_all" />
                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />
                    <TextView android:id="@+id/statAll" style="@style/StatValue" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/statsByLabelTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="14dp"
                android:fontFamily="@font/press_start_2p"
                android:text="@string/by_label"
                android:textSize="11sp" />

            <!-- Per-label rows are added here in code. -->
            <LinearLayout
                android:id="@+id/statsLabelList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/statsCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/close"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ===== Shop overlay ===== -->
    <ScrollView
        android:id="@+id/shopPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/shopTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/shop_title"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/shopHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/press_start_2p"
                android:lineSpacingExtra="4dp"
                android:text="@string/shop_help"
                android:textSize="9sp" />

            <!-- Flower rows are added here in code. -->
            <LinearLayout
                android:id="@+id/shopList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/shopCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/close"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ===== Garden overlay ===== -->
    <ScrollView
        android:id="@+id/gardenPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/gardenTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/garden_title"
                android:textSize="20sp" />

            <!-- Upgrade (left) + current size (right). -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/gardenUpgradeBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="0dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="12dp"
                    android:stateListAnimator="@null"
                    android:text="@string/garden_upgrade"
                    android:textSize="10sp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/gardenSizeLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/press_start_2p"
                    tools:ignore="HardcodedText"
                    android:text="4 × 4"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/gardenHelp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/press_start_2p"
                android:lineSpacingExtra="4dp"
                android:text="@string/garden_help"
                android:textSize="9sp" />

            <!-- The N×N grid of tiles is built here in code. -->
            <LinearLayout
                android:id="@+id/gardenGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/gardenCustomizeBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/garden_customize"
                android:textSize="13sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/gardenCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
