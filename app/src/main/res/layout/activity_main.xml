<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ===== Main timer screen ===== -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Top bar: theme (left) + settings (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="18dp">

            <ImageView
                android:id="@+id/themeBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_theme"
                android:src="@drawable/ic_palette" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/settingsBtn"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/cd_settings"
                android:src="@drawable/ic_settings" />
        </LinearLayout>

        <!-- Centered timer content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp">

            <TextView
                android:id="@+id/modeLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/work"
                android:textSize="22sp" />

            <TextView
                android:id="@+id/timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/press_start_2p"
                android:text="@string/initial_time"
                android:textSize="48sp" />

            <ProgressBar
                android:id="@+id/progress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="18dp"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="40dp"
                android:max="100"
                android:progress="100" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/startPauseBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="16dp"
                    android:stateListAnimator="@null"
                    android:text="@string/start"
                    android:textSize="14sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/resetBtn"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:fontFamily="@font/press_start_2p"
                    android:padding="16dp"
                    android:stateListAnimator="@null"
                    android:text="@string/reset"
                    android:textSize="14sp" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/switchModeBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:background="@android:color/transparent"
                android:fontFamily="@font/press_start_2p"
                android:stateListAnimator="@null"
                android:text="@string/switch_mode"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/sessionLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/press_start_2p"
                android:textSize="12sp"
                tools:ignore="HardcodedText"
                android:text="SESSION 1 / 4" />
        </LinearLayout>
    </LinearLayout>

    <!-- ===== Settings overlay ===== -->
    <ScrollView
        android:id="@+id/settingsPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/settingsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="36dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/settings"
                android:textSize="20sp" />

            <!-- Study (work) minutes -->
            <include
                android:id="@+id/rowWork"
                layout="@layout/row_stepper" />

            <!-- Break minutes -->
            <include
                android:id="@+id/rowBreak"
                layout="@layout/row_stepper" />

            <!-- Sessions -->
            <include
                android:id="@+id/rowSessions"
                layout="@layout/row_stepper" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/saveBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="36dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/save"
                android:textSize="14sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/settingsCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/close"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

    <!-- ===== Theme overlay ===== -->
    <ScrollView
        android:id="@+id/themePanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp">

            <TextView
                android:id="@+id/themeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="28dp"
                android:fontFamily="@font/press_start_2p"
                android:letterSpacing="0.1"
                android:text="@string/theme"
                android:textSize="20sp" />

            <!-- Theme buttons are added here in code -->
            <LinearLayout
                android:id="@+id/themeList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/themeCloseBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:fontFamily="@font/press_start_2p"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="@string/close"
                android:textSize="14sp" />
        </LinearLayout>
    </ScrollView>

</FrameLayout>
