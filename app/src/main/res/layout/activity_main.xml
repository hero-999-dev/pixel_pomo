<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/bg"
    android:padding="24dp">

    <TextView
        android:id="@+id/modeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:fontFamily="@font/press_start_2p"
        android:letterSpacing="0.1"
        android:text="@string/work"
        android:textColor="@color/work_green"
        android:textSize="22sp" />

    <TextView
        android:id="@+id/timer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/press_start_2p"
        android:text="@string/initial_time"
        android:textColor="@color/text_light"
        android:textSize="48sp" />

    <ProgressBar
        android:id="@+id/progress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="40dp"
        android:max="100"
        android:progress="100"
        android:progressDrawable="@drawable/progress_pixel" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/startPauseBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/btn_pixel"
            android:fontFamily="@font/press_start_2p"
            android:padding="16dp"
            android:stateListAnimator="@null"
            android:text="@string/start"
            android:textColor="@color/text_light"
            android:textSize="14sp" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/resetBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/btn_pixel_secondary"
            android:fontFamily="@font/press_start_2p"
            android:padding="16dp"
            android:stateListAnimator="@null"
            android:text="@string/reset"
            android:textColor="@color/text_light"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/switchModeBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:background="@android:color/transparent"
        android:fontFamily="@font/press_start_2p"
        android:stateListAnimator="@null"
        android:text="@string/switch_mode"
        android:textColor="@color/text_dim"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/roundLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/press_start_2p"
        android:textColor="@color/text_dim"
        android:textSize="12sp"
        tools:ignore="HardcodedText"
        xmlns:tools="http://schemas.android.com/tools"
        android:text="ROUND 1" />

</LinearLayout>
