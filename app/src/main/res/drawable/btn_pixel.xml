<?xml version="1.0" encoding="utf-8"?>
<!-- Primary pixel button: hard black drop-shadow + white border, no rounded corners. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="6dp" android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow" />
        </shape>
    </item>
    <item android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/accent" />
            <stroke android:width="3dp" android:color="@color/text_light" />
        </shape>
    </item>
</layer-list>
