<?xml version="1.0" encoding="utf-8"?>
<!-- Secondary pixel button: muted panel fill with a dim border. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:left="6dp" android:top="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow" />
        </shape>
    </item>
    <item android:right="6dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/panel" />
            <stroke android:width="3dp" android:color="@color/text_dim" />
        </shape>
    </item>
</layer-list>
